{
  "name": "@cubancodepath/nanobanana-mcp",
  "version": "1.1.0",
  "description": "MCP server for AI image generation powered by Google Gemini. Works with Claude Code and claude.ai Connectors.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nanobanana-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "icon.png"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "image-generation",
    "gemini",
    "ai",
    "claude",
    "nano-banana"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.0",
    "@cloudflare/workers-types": "^4.20260316.1",
    "@types/node": "^25.5.0",
    "agents": "^0.7.6",
    "hono": "^4.12.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.74.0"
  }
}
